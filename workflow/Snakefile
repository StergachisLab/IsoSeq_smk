rule add_tags_to_bam:
    conda:
        "envs/env.yml"
    input:
        bam="whatshap/{individual}_{condition}_{label}.haplotagged.bam",
        dictionary="tag/dictionary.tsv.gz",
    output:
        bam="tag/{individual}_{condition}_{label}.tagged.bam",
        bai="tag/{individual}_{condition}_{label}.tagged.bam.bai",
    log:
        "logs/add_tags_to_bam/{individual}_{condition}_{label}.tagged.log",
    benchmark:
        "benchmark/add_tags_to_bam/{individual}_{condition}_{label}_tagged.txt"
    threads: config.get("threads", 8)
    resources:
        runtime=530,
        mem_mb=20530,
    params:
        script=workflow.source_path("scripts/add_tags_to_bam.sh"),
        tmp_base=tmp_base,
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p "{params.tmp_base}"
        tmpdir=$(mktemp -d "{params.tmp_base}/snakemake.add_tags_to_bam.{wildcards.individual}.{wildcards.condition}.{wildcards.label}.XXXXXX")
        trap 'rm -rf "$tmpdir"' EXIT

        tmp_bam="$tmpdir/tagged.bam"
        tmp_bai="$tmpdir/tagged.bam.bai"

        bash {params.script} {input.bam} {input.dictionary} "$tmp_bam" {threads}

        if [ ! -s "$tmp_bai" ]; then
            samtools index -@ {threads} "$tmp_bam" "$tmp_bai"
        fi

        samtools quickcheck "$tmp_bam"

        mkdir -p "$(dirname {output.bam})"
        mv "$tmp_bam" {output.bam}
        mv "$tmp_bai" {output.bai}
        """


