        mv "$tmp_plots" {output.plots_dir}
        """


docs_dir = config["docs_dir"]
reference_genome = config["reference_genome"]


rule isoranker_analysis:
    input:
        read_stat="collapse/collapsed.read_stat.txt",
        sample_info=os.path.join(docs_dir, "Sample_info.tsv"),
        classification="pigeon/pigeon_classification.txt",
        gtf_file="annotations/annotations.sorted.gtf",
        genemap=os.path.join(docs_dir, "genemap2.txt"),
        hpo_file=os.path.join(docs_dir, "phenotype.hpoa"),
        probands_file=os.path.join(
            docs_dir, "Multiome_samples_clinical_findings_2.11.25.tsv"
        ),
    output:
        gene_with_phenotype=f"{output_dir}/browser/combined_results/merged_ranked_gene_with_phenotype.tsv.gz",
        isoform_with_phenotype=f"{output_dir}/browser/combined_results/merged_ranked_isoform_with_phenotype.tsv.gz",
        gene_lookup=f"{output_dir}/browser/lookup_tables/gene_coverage_lookup_table.tsv.gz",
        ranking_lookup=f"{output_dir}/browser/lookup_tables/sample_gene_rankings_lookup_table.tsv.gz",
        merged_gene=f"{output_dir}/intermediate/merged_ranked_gene.tsv.gz",
        merged_isoform=f"{output_dir}/intermediate/merged_ranked_isoform.tsv.gz",
        gene_div=f"{output_dir}/qc/gene_diversity.tsv.gz",
        isoform_div=f"{output_dir}/qc/isoform_diversity.tsv.gz",
        pca_plot=f"{output_dir}/qc/pca_plot.pdf",
    threads: config.get("threads", 4)
    log:
        f"logs/isoranker_analysis/isoranker.log",
    resources:
        runtime=530,
        mem_mb=500000,
    benchmark:
        f"benchmark/isoranker.txt"
    params:
        output_dir=lambda wildcards, output: os.path.commonpath(list(output)),
        ref_fa=reference_genome,
        tmp_base=tmp_base,
    conda:
        "envs/isoranker.yml"
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p "{params.tmp_base}"
        tmpdir=$(mktemp -d "{params.tmp_base}/snakemake.isoranker_analysis.XXXXXX")
        trap 'rm -rf "$tmpdir"' EXIT

        tmp_output_dir="$tmpdir/isoranker_output"
        mkdir -p "$tmp_output_dir"

        isoranker_pb_run_analysis \
          --read_stat_path {input.read_stat} \
          --reference_fasta_path {params.ref_fa} \
          --sample_info_path {input.sample_info} \
          --classification_path {input.classification} \
          --genemap_path {input.genemap} \
          --hpo_file_path {input.hpo_file} \
          --probands_file_path {input.probands_file} \
          --gtf_path_input {input.gtf_file} \
          --final_output_dir "$tmp_output_dir"

        test -s "$tmp_output_dir/browser/combined_results/merged_ranked_gene_with_phenotype.tsv.gz"
        test -s "$tmp_output_dir/browser/combined_results/merged_ranked_isoform_with_phenotype.tsv.gz"
        test -s "$tmp_output_dir/browser/lookup_tables/gene_coverage_lookup_table.tsv.gz"
        test -s "$tmp_output_dir/browser/lookup_tables/sample_gene_rankings_lookup_table.tsv.gz"
        test -s "$tmp_output_dir/intermediate/merged_ranked_gene.tsv.gz"
        test -s "$tmp_output_dir/intermediate/merged_ranked_isoform.tsv.gz"
        test -s "$tmp_output_dir/qc/gene_diversity.tsv.gz"
        test -s "$tmp_output_dir/qc/isoform_diversity.tsv.gz"
        test -s "$tmp_output_dir/qc/pca_plot.pdf"

        mkdir -p "$(dirname {output.gene_with_phenotype})"
        mkdir -p "$(dirname {output.gene_lookup})"
        mkdir -p "$(dirname {output.merged_gene})"
        mkdir -p "$(dirname {output.gene_div})"

        mv "$tmp_output_dir/browser/combined_results/merged_ranked_gene_with_phenotype.tsv.gz" {output.gene_with_phenotype}
        mv "$tmp_output_dir/browser/combined_results/merged_ranked_isoform_with_phenotype.tsv.gz" {output.isoform_with_phenotype}
        mv "$tmp_output_dir/browser/lookup_tables/gene_coverage_lookup_table.tsv.gz" {output.gene_lookup}
        mv "$tmp_output_dir/browser/lookup_tables/sample_gene_rankings_lookup_table.tsv.gz" {output.ranking_lookup}
        mv "$tmp_output_dir/intermediate/merged_ranked_gene.tsv.gz" {output.merged_gene}
        mv "$tmp_output_dir/intermediate/merged_ranked_isoform.tsv.gz" {output.merged_isoform}
        mv "$tmp_output_dir/qc/gene_diversity.tsv.gz" {output.gene_div}
        mv "$tmp_output_dir/qc/isoform_diversity.tsv.gz" {output.isoform_div}
        mv "$tmp_output_dir/qc/pca_plot.pdf" {output.pca_plot}
        """
