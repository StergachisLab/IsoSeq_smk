        tmp_bam="$tmpdir/aligned.bam"

        pbmm2 align {params.reference} {input} "$tmp_bam" \
            --preset ISOSEQ --sort -j {threads} --sort-memory 4G --log-level INFO

        samtools quickcheck "$tmp_bam"

        mkdir -p "$(dirname {output.aligned})"
        mv "$tmp_bam" {output.aligned}
        """


