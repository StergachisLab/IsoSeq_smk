rule merge_all_aligned:
    conda:
        "envs/env.yml"
    input:
        lambda wildcards: expand(
            "aligned/{individual}_aligned_labeled.bam",
            individual=config["individuals"].keys(),
        ),
    output:
        bam="aligned/all_individuals_aligned_merged.bam",
        bai="aligned/all_individuals_aligned_merged.bam.bai",
    log:
        "logs/merge_all_aligned/all_individuals_aligned_merged.log",
    threads: config.get("threads", 4)
    resources:
        runtime=530,
        mem_mb=10240,
    benchmark:
        "benchmark/merge_all_aligned/all_aligned_merged.txt"
    params:
        tmp_base=tmp_base,
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p "{params.tmp_base}"
        tmpdir=$(mktemp -d "{params.tmp_base}/snakemake.merge_all_aligned.XXXXXX")
        trap 'rm -rf "$tmpdir"' EXIT

        tmp_bam="$tmpdir/all_individuals_aligned_merged.bam"
        tmp_bai="$tmpdir/all_individuals_aligned_merged.bam.bai"

        samtools merge \
            --write-index -@ {threads} \
            "$tmp_bam##idx##$tmp_bai" {input}

        samtools quickcheck "$tmp_bam"

        mkdir -p "$(dirname {output.bam})"
        mv "$tmp_bam" {output.bam}
        mv "$tmp_bai" {output.bai}
        """


rule collapse:
    conda:
        "envs/env2.yml"
    input:
        bam="aligned/all_individuals_aligned_merged.bam",
        bai="aligned/all_individuals_aligned_merged.bam.bai",
    output:
        collapsed_gff="collapse/collapsed.gff",
        collapsed_abundance="collapse/collapsed.abundance.txt",
        collapsed_readstat="collapse/collapsed.read_stat.txt",
        collapsed_count="collapse/collapsed.flnc_count.txt",
    log:
        "logs/collapse/collapsed.log",
    threads: config.get("threads", 4)
    resources:
        runtime=930,
        mem_mb=20530,
    benchmark:
        "benchmark/collapse/collapse.txt"
    params:
        tmp_base=tmp_base,
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p "{params.tmp_base}"
        tmpdir=$(mktemp -d "{params.tmp_base}/snakemake.collapse.XXXXXX")
        trap 'rm -rf "$tmpdir"' EXIT

        tmp_gff="$tmpdir/collapsed.gff"
        tmp_abundance="$tmpdir/collapsed.abundance.txt"
        tmp_readstat="$tmpdir/collapsed.read_stat.txt"
        tmp_count="$tmpdir/collapsed.flnc_count.txt"

        isoseq collapse --do-not-collapse-extra-5exons --num-threads {threads} {input.bam} "$tmp_gff"

        test -s "$tmp_gff"
        test -s "$tmp_abundance"
        test -s "$tmp_readstat"
        test -s "$tmp_count"

        mkdir -p "$(dirname {output.collapsed_gff})"
        mv "$tmp_gff" {output.collapsed_gff}
        mv "$tmp_abundance" {output.collapsed_abundance}
        mv "$tmp_readstat" {output.collapsed_readstat}
        mv "$tmp_count" {output.collapsed_count}
        """


rule pigeon_prepare_annot:
    conda:
        "envs/env2.yml"
    input:
        gtf=config["pigeon_annot"],
        collapsed_gff="collapse/collapsed.gff",
    output:
        gtf="annotations/annotations.sorted.gtf",
        pgi="annotations/annotations.sorted.gtf.pgi",
        prepared_collapsed="pigeon/collapsed.prepared.gff",
        prepared_collapsed_pgi="pigeon/collapsed.prepared.gff.pgi",
    params:
        script=workflow.source_path("scripts/clean_pigeon_gtf.awk"),
        tmp_base=tmp_base,
    log:
        "logs/pigeon_prepare_annot/pigeon_prepare.log",
    benchmark:
        "benchmark/pigeon_prepare/annotation_sort.txt"
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p "{params.tmp_base}"
        tmpdir=$(mktemp -d "{params.tmp_base}/snakemake.pigeon_prepare_annot.XXXXXX")
        trap 'rm -rf "$tmpdir"' EXIT

        tmp_annotations="$tmpdir/annotations"
        tmp_pigeon="$tmpdir/pigeon"
        mkdir -p "$tmp_annotations" "$tmp_pigeon"

        raw_gtf="$tmp_annotations/annotations.raw.gtf"
        clean_gtf="$tmp_annotations/annotations.clean.gtf"

        if file {input.gtf} | grep -q 'gzip compressed'; then
            gunzip -c {input.gtf} > "$raw_gtf"
        else
            cp {input.gtf} "$raw_gtf"
        fi

        awk -f {params.script} "$raw_gtf" > "$clean_gtf"

        (
            cd "$tmp_annotations"
            pigeon prepare "annotations.clean.gtf"
        )

        cp {input.collapsed_gff} "$tmp_pigeon/collapsed.prepared.gff"

        (
            cd "$tmp_pigeon"
            pigeon prepare "collapsed.prepared.gff"
        )

        test -s "$tmp_annotations/annotations.clean.sorted.gtf"
        test -s "$tmp_annotations/annotations.clean.sorted.gtf.pgi"
        test -s "$tmp_pigeon/collapsed.prepared.sorted.gff"
        test -s "$tmp_pigeon/collapsed.prepared.sorted.gff.pgi"

        mkdir -p "$(dirname {output.gtf})"
        mkdir -p "$(dirname {output.prepared_collapsed})"

        mv "$tmp_annotations/annotations.clean.sorted.gtf" {output.gtf}
        mv "$tmp_annotations/annotations.clean.sorted.gtf.pgi" {output.pgi}
        mv "$tmp_pigeon/collapsed.prepared.sorted.gff" {output.prepared_collapsed}
        mv "$tmp_pigeon/collapsed.prepared.sorted.gff.pgi" {output.prepared_collapsed_pgi}
        """


rule pigeon_process:
    conda:
        "envs/env2.yml"
    input:
        prepared_collapsed="pigeon/collapsed.prepared.gff",
        collapsed_count="collapse/collapsed.flnc_count.txt",
        prepared_gtf="annotations/annotations.sorted.gtf",
        prepared_index="annotations/annotations.sorted.gtf.pgi",
    output:
        classification="pigeon/pigeon_classification.txt",
        report="pigeon/saturation.txt",
    log:
        "logs/pigeon_process/pigeon_process.log",
    params:
        reference=config["reference_genome"],
        tmp_base=tmp_base,
    benchmark:
        "benchmark/pigeon_process/pigeon.txt"
    threads: config.get("threads", 4)
    resources:
        runtime=530,
        mem_mb=76800,
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p "{params.tmp_base}"
        tmpdir=$(mktemp -d "{params.tmp_base}/snakemake.pigeon_process.XXXXXX")
        trap 'rm -rf "$tmpdir"' EXIT

        tmp_pigeon="$tmpdir/pigeon"
        mkdir -p "$tmp_pigeon"

        pigeon classify {input.prepared_collapsed} {input.prepared_gtf} {params.reference} \
            --flnc {input.collapsed_count} -d "$tmp_pigeon" -o 'pigeon'

        pigeon filter "$tmp_pigeon/pigeon_classification.txt"
        pigeon report "$tmp_pigeon/pigeon_classification.filtered_lite_classification.txt" "$tmp_pigeon/saturation.txt"

        test -s "$tmp_pigeon/pigeon_classification.txt"
        test -s "$tmp_pigeon/saturation.txt"

        mkdir -p "$(dirname {output.classification})"
        mv "$tmp_pigeon/pigeon_classification.txt" {output.classification}
        mv "$tmp_pigeon/saturation.txt" {output.report}

        # Preserve filtered outputs if Pigeon produced them.
        for f in "$tmp_pigeon"/pigeon_classification.filtered*; do
            if [ -e "$f" ]; then
                mv "$f" "$(dirname {output.classification})/"
            fi
        done
        """


