rule create_cluster_fofn:
    conda:
        "envs/env.yml"
    input:
        bam=combine_labels,
    output:
        fofn="fofn/{individual}.file.fofn",
    log:
        "logs/create_cluster_fofn/{individual}.file.fofn.log",
    threads: config.get("threads", 4)
    resources:
        runtime=530,
    benchmark:
        "benchmark/create_cluster_fofn/{individual}.txt"
    params:
        tmp_base=tmp_base,
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p "{params.tmp_base}"
        tmpdir=$(mktemp -d "{params.tmp_base}/snakemake.create_cluster_fofn.{wildcards.individual}.XXXXXX")
        trap 'rm -rf "$tmpdir"' EXIT

        tmp_fofn="$tmpdir/file.fofn"

        input_files=({input.bam})

        if [ ${{#input_files[@]}} -eq 0 ]; then
            echo "ERROR: No BAM files found for {wildcards.individual}" >&2
            exit 1
        fi

        : > "$tmp_fofn"

        for bam in "${{input_files[@]}}"; do
            if [ ! -s "$bam" ]; then
                echo "ERROR: BAM listed for clustering does not exist or is empty: $bam" >&2
                exit 1
            fi

            realpath "$bam" >> "$tmp_fofn"
        done

        echo "Wrote absolute-path FOFN for {wildcards.individual}:"
        cat "$tmp_fofn"

        mkdir -p "$(dirname {output.fofn})"
        mv "$tmp_fofn" {output.fofn}
        """


rule cluster:
    conda:
        "envs/env2.yml"
    input:
        fofn="fofn/{individual}.file.fofn",
    log:
        "logs/cluster/{individual}.log",
    output:
        clustered="clustered/{individual}_clustered.bam",
    threads: 20
    resources:
        runtime=2880,
        mem_mb=102400,
    benchmark:
        "benchmark/cluster/{individual}.txt"
    params:
        tmp_base=tmp_base,
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p "{params.tmp_base}"
        tmpdir=$(mktemp -d "{params.tmp_base}/snakemake.cluster.{wildcards.individual}.XXXXXX")
        trap 'rm -rf "$tmpdir"' EXIT

        tmp_clustered="$tmpdir/clustered.bam"

        isoseq cluster2 {input.fofn} "$tmp_clustered" -j {threads} --singletons

        samtools quickcheck "$tmp_clustered"

        mkdir -p "$(dirname {output.clustered})"
        mv "$tmp_clustered" {output.clustered}
        """


