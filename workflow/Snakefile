        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p "{params.tmp_base}"
        tmpdir=$(mktemp -d "{params.tmp_base}/snakemake.align.{wildcards.individual}.XXXXXX")
