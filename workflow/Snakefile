    benchmark: "benchmark/label_transcripts/{individual}_aligned_labeled.txt"
    resources: runtime=530, mem_mb=10240
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        (
            samtools view -@ {threads} -h {input.bam} \
            | awk -v id={wildcards.individual} 'BEGIN {{OFS="\t"}} !/^@/ {{$1=id"_"$1; print}} /^@/ {{print}}'
        ) | samtools view -@ {threads} -bS - > {output.bam}
        """

