"""
Snakefile rewritten to use Snakemake shadow directories on node-local /tmp.

Run like:
    snakemake -j 32 --directory /gscratch/your/project \
              --shadow-prefix /tmp \
              --rerun-incomplete

Key points:
- Every heavy rule now has `shadow: "copy-minimal"` (or "minimal" where read-only inputs are safe).
- Outputs stay in /gscratch (or whatever you set with --directory). Snakemake copies them back automatically from /tmp.
- Inputs are symlinked/copied into the shadow dir; commands run inside that dir, so relative paths work and I/O hits local disk.
- You can switch modes globally by changing SHADOW_MODE below.

If you need to exclude a rule from shadowing (e.g., requires absolute paths), just remove the `shadow:` line from that rule.
"""

import os
import yaml
from pathlib import Path
from snakemake.utils import min_version

min_version("7.0")

# ---------------------------------------------------------------------------
# Global configuration & helpers
# ---------------------------------------------------------------------------

# Honor external config file path via env var, fallback to repo default
configfile: os.environ.get("SNAKEMAKE_CONFIG", "config/github.config.yaml")

# Choose your preferred shadow mode here
#   "copy-minimal"  -> copy only declared inputs
#   "minimal"       -> symlink declared inputs
#   "copy"          -> copy whole workdir
SHADOW_MODE = config.get("shadow_mode", "copy-minimal")

# Respect Snakemake's --directory flag; all relative paths are resolved there.
PROJECT_ROOT = workflow.workdir if hasattr(workflow, "workdir") else os.getcwd()

# Convenience flags from config
run_isoranker = config.get("run_isoranker", False)
output_dir    = config.get("output_dir", "Output")

# Individuals and their conditions/labels
individuals = config["individuals"].keys()

conditions_per_individual = {
    ind: [
        cond
        for cond in ["treated", "untreated"]
        if cond in config["individuals"][ind]
        and isinstance(config["individuals"][ind][cond], dict)
        and len(config["individuals"][ind][cond]) > 0
    ]
    for ind in individuals
}

labels = {
    ind: {
        cond: list(config["individuals"][ind][cond].keys())
        for cond in conditions_per_individual[ind]
    }
    for ind in individuals
}

# Build valid combinations
combinations = []
for ind in individuals:
    for cond in conditions_per_individual[ind]:
        for lbl in labels[ind][cond]:
            files = config["individuals"][ind][cond][lbl]
            if isinstance(files, list) and len(files) > 0:
                combinations.append({"individual": ind, "condition": cond, "label": lbl})

# Wildcard constraints
wildcard_constraints:
    individual="|".join(individuals),
    condition="|".join(sorted(set(c for cc in conditions_per_individual.values() for c in cc))),
    label="|".join(sorted({lbl for ind in individuals for cond in conditions_per_individual[ind] for lbl in labels[ind][cond]})),

# Include common helper rules if needed
include: "rules/common.smk"

def combine_labels(wildcards):
    """Return list of BAMs for merge_samples rule."""
    ind = wildcards.individual
    bams = []
    for cond in conditions_per_individual[ind]:
        for lbl in labels[ind][cond]:
            bams.append(f"whatshap/{ind}_{cond}_{lbl}.haplotagged.bam")
    return bams

# Convenience outputs from isoranker stage
isoranker_outputs = [
    f"{output_dir}/browser/combined_results/merged_ranked_gene_with_phenotype.tsv.gz",
    f"{output_dir}/browser/combined_results/merged_ranked_isoform_with_phenotype.tsv.gz",
    f"{output_dir}/browser/lookup_tables/gene_coverage_lookup_table.tsv.gz",
    f"{output_dir}/browser/lookup_tables/sample_gene_rankings_lookup_table.tsv.gz",
    f"{output_dir}/intermediate/merged_ranked_gene.tsv.gz",
    f"{output_dir}/intermediate/merged_ranked_isoform.tsv.gz",
    f"{output_dir}/qc/gene_diversity.tsv.gz",
    f"{output_dir}/qc/isoform_diversity.tsv.gz",
    f"{output_dir}/qc/pca_plot.pdf",
]

# ---------------------------------------------------------------------------
# Rule: all
# ---------------------------------------------------------------------------
rule all:
    input:
        expand("tag/{individual}_{condition}_{label}.tagged.bam", zip, individual=[c["individual"] for c in combinations], condition=[c["condition"] for c in combinations], label=[c["label"] for c in combinations]),
        expand("qc/{individual}_{condition}_{label}_qc_summary.tsv", zip, individual=[c["individual"] for c in combinations], condition=[c["condition"] for c in combinations], label=[c["label"] for c in combinations]),
        expand("qc/{individual}_{condition}_{label}_plots", zip, individual=[c["individual"] for c in combinations], condition=[c["condition"] for c in combinations], label=[c["label"] for c in combinations]),
        *( ["collapse/collapsed.gff"] if combinations else [] ),
        *( ["tag/dictionary.tsv.gz"] if combinations else [] ),
        *( ["pigeon/sorted.gff"] if combinations else [] ),
        *( ["pigeon/pigeon_classification.txt"] if combinations else [] ),
        *( isoranker_outputs if run_isoranker else [] ),

# ---------------------------------------------------------------------------
# Rules below: each with `shadow: SHADOW_MODE`
# ---------------------------------------------------------------------------

rule merge_individual_condition:
    shadow: SHADOW_MODE
    conda:  "envs/env.yml"
    input:  get_merge_input
    output: bam="merged/{individual}_{condition}_{label}_merged.bam"
    log:    "logs/merge_individual_condition/{individual}_{condition}_{label}_merged.log"
    threads: config.get("threads", 4)
    resources: runtime=930
    params:
        max_reads        = config["max_reads"],
        downsample_reads = config["downsample_reads"]
    benchmark: "benchmark/merge_individual_condition/{individual}_{condition}_{label}.txt"
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        max_reads={params.max_reads}
        downsample_reads={params.downsample_reads}

        input_files=({input})
        num_files=${#input_files[@]}

        if [ $num_files -eq 1 ]; then
            cp {input} {output.bam}
        else
            samtools merge -@ {threads} {output.bam} {input}
        fi

        total_reads=$(samtools view -@ {threads} -c {output.bam})
        echo "Total reads in merged BAM: $total_reads"

        if (( total_reads > max_reads )); then
            echo "Downsampling to ~$downsample_reads reads..."
            temp_bam=$(mktemp)
            fraction=$(echo "scale=6; $downsample_reads / $total_reads" | bc)
            fraction=$(echo "$fraction" | sed 's/^0//')
            samtools view -@ {threads} -s 42$fraction -b {output.bam} > "$temp_bam"
            mv "$temp_bam" {output.bam}
        else
            echo "No downsampling needed."
        fi
        """

rule label_reads_with_condition:
    shadow: SHADOW_MODE
    conda:  "envs/env.yml"
    input:  bam="merged/{individual}_{condition}_{label}_merged.bam"
    output: bam=temp("merged/{individual}_{condition}_{label}_labeled.bam")
    log:    "logs/label_reads_with_condition/{individual}_{condition}_{label}_labeled.log"
    benchmark: "benchmark/label_reads_condition/{individual}_{condition}_{label}.txt"
    threads: config.get("threads", 4)
    resources: runtime=930
    shell:
        """
        exec &> >(tee -a {log})
        set -euo pipefail

        samtools view -@ {threads} -h {input.bam} | \
        awk -v id="{wildcards.individual}_{wildcards.condition}_{wildcards.label}" 'BEGIN {{OFS="\t"}} !/^@/ {{$1=id"_"$1; print}} /^@/ {{print}}' | \
        samtools view -@ {threads} -o {output.bam}
        """

rule align_sample:
    shadow: SHADOW_MODE
    conda:  "envs/env.yml"
    input:
        reference=ancient(config["reference_genome"]),
        bam="merged/{individual}_{condition}_{label}_labeled.bam"
    output:
        aligned=temp("aligned/{individual}_{condition}_{label}_aligned.bam"),
        bai=temp("aligned/{individual}_{condition}_{label}_aligned.bam.bai")
